{\n    "name": "security-visitor-management-system",\n    "description": "A Laravel project for managing visitor security.",\n    "type": "project",\n    "require": {\n        "php": "^7.3|^8.0",\n        "fideloper/proxy": "^4.4",\n        "laravel/framework": "^8.0",\n        "laravel/tinker": "^2.0"\n    },\n    "autoload": {\n        "psr-4": {\n            "App\\": "app/"\n        }\n    },\n    "scripts": {\n        "post-autoload-dump": [\n            "Illuminate\Foundation\ComposerScripts::postAutoloadDump",\n            "php artisan package:discover --ansi"\n        ],\n        "post-create-project-cmd": [\n            "php artisan key:generate --ansi"\n        ]\n    },\n    "minimum-stability": "dev",\n    "prefer-stable": true\n}